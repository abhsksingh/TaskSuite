# MongoDB connection
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/tasksuite?retryWrites=true&w=majority"

# JWT secrets (change these!)
JWT_ACCESS_SECRET="your-random-access-secret"
JWT_REFRESH_SECRET="your-random-refresh-secret"

# Token expiry
ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# Backend port (Railway sets this automatically via PORT)
PORT=3001

# Frontend URL for CORS (required for production)
# For Railway: https://<your-frontend>.railway.app
# For local: http://localhost:5173
FRONTEND_URL="http://localhost:5173"
